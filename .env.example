# Telegram Bot @MaryBloomsBot (Mary Blooms)
# Локально: скопируйте в .env — npm run webhook:set подхватит переменные автоматически
TELEGRAM_BOT_TOKEN=

# Опционально: секрет для webhook
TELEGRAM_WEBHOOK_SECRET=

# URL сайта для отправки PDF (на Vercel подставляется автоматически через VERCEL_URL)
SITE_URL=https://your-domain.vercel.app

# Кнопки после PDF
TELEGRAM_PLANT_REVIEW_URL=https://t.me/mary.bloooms?text=Разобрать%20моё%20растение
TELEGRAM_MATERIALS_URL=https://t.me/maryblooms_chat

# Имя PDF-файла (доступен по /assets/pdf/ после деплоя)
PDF_FILE_NAME=shpargalka-mary-blooms.pdf

# Vercel KV / Upstash Redis (опционально, для сохранения chat_id)
# Vercel Dashboard → Storage → Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
